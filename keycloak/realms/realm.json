{
  "realm": "oprosita",
  "enabled": true,
  "loginTheme": "oprositaTheme",
  "clients": [
    {
      "clientId": "angular-app",
      "enabled": true,
      "publicClient": true,
      "redirectUris": ["http://localhost:4200/*"],
      "webOrigins": ["*"],
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect",
      "optionalClientScopes": [
        "offline_access"
      ],
      "attributes": {
        "client.offline.access": "true"
      }
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "profesor",
        "description": "Acceso como profesor"
      },
      {
        "name": "alumno",
        "description": "Acceso como alumno"
      },
      {
        "name": "offline_access",
        "description": "${role_offline-access}"
      }
    ]
  },
  "users": [
    {
      "username": "profesor",
      "enabled": true,
      "email": "profe@oprosita.test",
      "emailVerified": true,
      "firstName": "Profe",
      "lastName": "Prueba",
      "credentials": [
        {
          "type": "password",
          "value": "profesor",
          "temporary": false
        }
      ],
      "realmRoles": ["profesor", "offline_access"]
    },
    {
      "username": "alumno",
      "enabled": true,
      "email": "alumno@oprosita.test",
      "emailVerified": true,
      "firstName": "Alumno",
      "lastName": "Prueba",
      "credentials": [
        {
          "type": "password",
          "value": "alumno",
          "temporary": false
        }
      ],
      "realmRoles": ["alumno", "offline_access"]
    }
  ]
}
